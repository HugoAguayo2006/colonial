{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },

    {
      "source": "/actividadesextracurriculares",
      "destination": "/vida-colonial/extracurriculares",
      "permanent": true
    },
    {
      "source": "/inscripcionesprimaria",
      "destination": "/inscripciones/primaria",
      "permanent": true
    },
    {
      "source": "/primaria",
      "destination": "/niveles/primaria",
      "permanent": true
    },
    {
      "source": "/nosotros",
      "destination": "/conocenos",
      "permanent": true
    },
    {
      "source": "/inscripcionessecundaria",
      "destination": "/inscripciones/secundaria",
      "permanent": true
    },
    {
      "source": "/otrosservicios",
      "destination": "/vida-colonial/otros-servicios",
      "permanent": true
    },
    {
      "source": "/eventos",
      "destination": "/vida-colonial/eventos",
      "permanent": true
    },
    {
      "source": "/galeria",
      "destination": "/vida-colonial/galeria",
      "permanent": true
    },
    {
      "source": "/secundaria",
      "destination": "/niveles/secundaria",
      "permanent": true
    },

    {
      "source": "/book-online",
      "destination": "/contacto",
      "permanent": true
    },
    {
      "source": "/instalaciones",
      "destination": "/conocenos",
      "permanent": true
    },
    {
      "source": "/seguridad",
      "destination": "/conocenos",
      "permanent": true
    },
    {
      "source": "/service-page/junta-con-las-directoras",
      "destination": "/contacto",
      "permanent": true
    },
    {
      "source": "/service-page/recorrido-presencial-por-la-escuela",
      "destination": "/contacto",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/)(?!.*\\.[^/]+$).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/icons/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/favicon.svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/favicon-96x96.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/apple-touch-icon.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/site.webmanifest",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' https: data: blob: https://maps.googleapis.com https://maps.gstatic.com https://*.googleusercontent.com; script-src 'self' 'unsafe-inline' https://www.youtube.com https://www.youtube-nocookie.com https://www.google.com https://maps.googleapis.com https://maps.gstatic.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; frame-src 'self' https://www.youtube.com https://www.youtube-nocookie.com https://www.google.com; connect-src 'self' https://api.emailjs.com https://maps.googleapis.com https://maps.gstatic.com;"
        }
      ]
    }
  ]
}
